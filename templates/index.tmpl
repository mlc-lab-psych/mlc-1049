                        box-sizing: border-box;
                    }

                    h2 {
                        margin-top: 0;
                    }

                    label {
                        display: block;
                        font-size: .8rem;
                        font-weight: 600;
                        text-transform: uppercase;
                        letter-spacing: .05em;
                        color: #3d6b4f;
                        margin-bottom: 8px;
                    }

                    input {
                        width: 100%;
                        padding: 12px;
                        font-size: 16px;
                        box-sizing: border-box;
                    }

                    .hint {
                        color: #777;
                        font-size: .85rem;
                        margin-top: 8px;
                    }

                    button {
                        margin-top: 30px;
                        padding: 12px 28px;
                        font-size: 16px;
                        cursor: pointer;
                    }
                </style>

                <div class="card">
                    <h2>Prolific ID</h2>

                    <input
                        id="pid"
                        value="${worker_id}"
                        placeholder="Enter your Prolific PID"
                    >

                    <div class="hint">
                        This should already be filled in if you opened the study from Prolific.
                    </div>

                    <button id="continue">
                        Continue
                    </button>
                </div>
            `;

            document.getElementById("continue").onclick = async () => {
                const pid = document.getElementById("pid").value.trim();

                if (!pid) {
                    alert("Please enter your Prolific PID.");
                    return;
                }

                worker_id = pid;

                document.body.innerHTML = "";

                await fetchData();
            };
        }

