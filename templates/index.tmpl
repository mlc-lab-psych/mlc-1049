<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>IAT Experiment Template</title>
    <script defer src="https://unpkg.com/jspsych@8.0.0"></script>
    <link href="https://unpkg.com/jspsych@8.0.0/css/jspsych.css" rel="stylesheet" type="text/css" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <link rel="stylesheet" href="/static/css/styles.css">
    <link rel="preload" as="image" href="/static/images/words_animate_Cat1.png">
    <link rel="preload" as="image" href="/static/images/words_animate_Cat2.png">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Roboto:ital,wght@0,100..900;1,100..900&display=swap" rel="stylesheet">

    <script defer src="https://unpkg.com/@jspsych/plugin-html-keyboard-response@1.1.3"></script>
    <script defer src="https://unpkg.com/@jspsych/plugin-survey-html-form@1.0.3"></script>
    <script defer src="https://unpkg.com/@jspsych/plugin-iat-html@1.1.3"></script>
    <script defer src="https://unpkg.com/@jspsych/plugin-survey-multi-select@1.1.3"></script>

    <script>
        const apiBase = "{{ .ServerHost }}";
        console.warn = () => {};

        function getParamFromURL(name) {
            name = name.replace(/\[/, "\\[").replace(/]/, "\\]");
            let regex = new RegExp("[?&]" + name + "=([^&#]*)");
            let results = regex.exec(window.location.href);
            try{
                let decoded = decodeURIComponent(results[1])
                return results ? decoded : "";
            }
            catch(error){
                return ""
            }
        }

        let timeline = []
        let worker_id = getParamFromURL('PROLIFIC_PID');

        async function preload_images(data){
            let preloadedImages = []
            data.forEach(img=>{
                let ogImg = new Image();
                ogImg.src = img;
                preloadedImages.push(ogImg)
            })
            return preloadedImages
        }

        async function fetchData() {
            try {
                if (worker_id === "") {
                    console.log("No ID!")
                    response = await fetch(`${apiBase}/api/v1/data`, {
                        method: "GET",
                    }); // Make the request
                } else {
                    response = await fetch(`${apiBase}/api/v1/data`, {
                        method: "PUT",
                        headers: {
                            'Content-Type': 'application/json'
                        },
                        body: JSON.stringify({
                            worker_id: encodeURIComponent(worker_id)
                        })
                    }); // Make the request
                }
                

                if (!response.ok) {
                    throw new Error(`HTTP error! status: ${response.status}`);
                }
                const result = await response.json();
                const data = result.data;
                const session = result.session

                console.log(data)

                let current_block = 0
                let test_block_stimuli = []
                let temp_block = []

                for(let i = 0; i < data['test_stimuli'].length; i++){
                    if(data['test_stimuli'][i]['block'] === current_block){
                        temp_block.push(data['test_stimuli'][i])
                        if(data['test_stimuli'][i]['stimulus_type'] === "image"){
                            const image_url = data['test_stimuli'][i]['stimulus'];
                            data['test_stimuli'][i]['stimulus'] = `<img src="${image_url}"  alt=""/>`;
                        }
                    }
                    else{
                        test_block_stimuli.push(temp_block)
                        current_block += 1
                        temp_block = [data['test_stimuli'][i]]
                        if(data['test_stimuli'][i]['stimulus_type'] === "image"){
                            const image_url = data['test_stimuli'][i]['stimulus'];
                            data['test_stimuli'][i]['stimulus'] = `<img src="${image_url}"  alt=""/>`;
                        }
                    }
                }

                test_block_stimuli.push(temp_block)

                images = data['images']
                await preload_images(images).then((result) => {
                    images = result
                })

                category_displays = data['category_display']
                cat_img = data['category_word_image']

                test_stimuli = test_block_stimuli;

                console.log(category_displays, cat_img, test_stimuli)

                initializeJsPsych(worker_id, session);

            } catch (error) {
                console.error('Error fetching data:', error);
            }
        }

